{
  "expo": {
    "name": "mydhobi",
    "slug": "mydhobi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/mdlogo.png",
    "scheme": "mydhobi",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "backgroundImage": "./assets/images/mdlogo.png"
        
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.softravi.mydhobi",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fff",
          "android": {
            "image": "./assets/images/mdlogo.png",
            "resizeMode":"contain",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bc782274-b247-4963-a09e-882371952c5d"
      }
    }
  }
}
